{
  "manifest_version": 3,
  "name": "Naviga - New Tab Bookmarks",
  "version": "1.0.0",
  "description": "Edge style bookmark navigation for your new tab",
  "permissions": [
    "bookmarks",
    "storage"
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
