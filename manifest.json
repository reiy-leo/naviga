{
  "manifest_version": 3,
  "name": "Naviga",
  "version": "1.0.0",
  "description": "Workspace-based bookmark navigation for Edge new tab",
  "permissions": ["bookmarks", "storage", "newtab"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
